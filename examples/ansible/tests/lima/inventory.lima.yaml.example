# =============================================================================
# SAMPLE inventory — do NOT edit this file.
# =============================================================================
#
# This file shows the SHAPE of the real inventory.lima.yaml that is GENERATED
# by scripts/up.sh. The real file is written to inventory.lima.yaml (next to
# this .example) after the VMs are up and is git-ignored.
#
# Re-run scripts/up.sh to regenerate inventory.lima.yaml — the SSH local ports
# and user-v2 IPs are discovered at runtime and will differ from the values
# shown below.
#
# Each host is reached over SSH via a forwarded localhost port (ansible_port),
# while patroni_node_address carries the VM's user-v2 IP (192.168.104.x) that
# etcd and Patroni advertise to the rest of the cluster.
# =============================================================================
patroni_postgresql_cluster:
  hosts:
    patroni-postgresql-01:
      ansible_host: 127.0.0.1
      ansible_port: 60001
      ansible_user: fedor
      ansible_ssh_private_key_file: ~/.lima/_config/user
      patroni_node_address: 192.168.104.11
    patroni-postgresql-02:
      ansible_host: 127.0.0.1
      ansible_port: 60002
      ansible_user: fedor
      ansible_ssh_private_key_file: ~/.lima/_config/user
      patroni_node_address: 192.168.104.12
    patroni-postgresql-03:
      ansible_host: 127.0.0.1
      ansible_port: 60003
      ansible_user: fedor
      ansible_ssh_private_key_file: ~/.lima/_config/user
      patroni_node_address: 192.168.104.13
  vars:
    ansible_python_interpreter: /usr/bin/python3
